#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
log_info() { echo -e "${GREEN}>${NC} $1"; }
log_warn() { echo -e "${YELLOW}!${NC} $1"; }
log_error() { echo -e "${RED}x${NC} $1"; }

if [[ $# -lt 1 ]]; then
  echo "Usage: workon <shortcut-id> [description]"
  echo ""
  echo "Examples:"
  echo "  workon 12345                       # Branch: sc-12345"
  echo "  workon 12345 add user export       # Branch: sc-12345-add-user-export"
  echo "  workon sc-12345 fix login bug      # Branch: sc-12345-fix-login-bug"
  echo "  workon fix-login-bug               # Branch: fix-login-bug (custom)"
  exit 1
fi

story_input="$1"; shift
description="$*"

worktree_path=$(git rev-parse --show-toplevel 2>/dev/null)
if [[ -z "$worktree_path" ]]; then
  log_error "Not in a git repository"; exit 1
fi
dir_name=$(basename "$worktree_path")

worktree_count=$(git worktree list 2>/dev/null | wc -l | tr -d ' ')
is_primary=false
if [[ "$worktree_count" -gt 1 ]]; then
  main_worktree=$(git worktree list 2>/dev/null | head -1 | awk '{print $1}')
  main_worktree_name=$(basename "$main_worktree")
  [[ "$dir_name" == "$main_worktree_name" ]] && is_primary=true
fi

if ! git diff-index --quiet HEAD -- 2>/dev/null; then
  log_error "Uncommitted changes present. Commit or stash first."; exit 1
fi
if [[ -n "$(git status --porcelain)" ]]; then
  log_error "Untracked or modified files present. Clean up first."; exit 1
fi

log_info "Fetching origin/main..."
git fetch origin main
current_branch=$(git rev-parse --abbrev-ref HEAD)

if [[ "$worktree_count" -gt 1 && "$is_primary" == false ]]; then base_branch="$dir_name"; else base_branch="main"; fi

if [[ "$current_branch" != "$base_branch" && "$current_branch" != "main" ]]; then
  log_warn "Currently on branch '$current_branch', switching to '$base_branch' first"
  git checkout "$base_branch" 2>/dev/null || git checkout -b "$base_branch"
fi

log_info "Rebasing against origin/main..."
git rebase origin/main

if [[ "$story_input" =~ ^(sc-)?([0-9]+)$ ]]; then
  story_id="${BASH_REMATCH[2]}"
  if [[ -n "$description" ]]; then
    slug=$(echo "$description" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-')
    slug=${slug#-}; slug=${slug%-}
    branch_name="sc-${story_id}-${slug}"
  else
    branch_name="sc-${story_id}"
  fi
  log_info "Shortcut story #${story_id} -> branch: $branch_name"
else
  branch_name=$(echo "$story_input" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-')
  branch_name=${branch_name#-}; branch_name=${branch_name%-}
fi

if [[ -z "$branch_name" ]]; then
  log_error "Could not derive branch name from '$story_input'"; exit 1
fi

if [[ "$current_branch" == "$branch_name" ]]; then
  log_info "Already on branch $branch_name"
elif git show-ref --verify --quiet "refs/heads/$branch_name" 2>/dev/null; then
  log_info "Checking out existing branch $branch_name..."
  git checkout "$branch_name"
else
  log_info "Creating branch $branch_name..."
  git checkout -b "$branch_name"
fi

if [[ -n "${TMUX:-}" ]]; then
  tmux rename-window -t "$TMUX_PANE" "$branch_name"
  log_info "Tmux window renamed to $branch_name"
fi

log_info "Ready to work on $branch_name"
if [[ "$branch_name" =~ ^sc-([0-9]+) ]]; then
  story_id="${BASH_REMATCH[1]}"
  echo ""
  log_info "Shortcut: https://app.shortcut.com/peel/story/${story_id}"
fi
