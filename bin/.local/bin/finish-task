#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
log_info() { echo -e "${GREEN}→${NC} $1"; }
log_warn() { echo -e "${YELLOW}!${NC} $1"; }
log_error() { echo -e "${RED}✗${NC} $1"; }

worktree_path=$(git rev-parse --show-toplevel 2>/dev/null)
if [[ -z "$worktree_path" ]]; then
  log_error "Not in a git repository"; exit 1
fi
dir_name=$(basename "$worktree_path")
current_branch=$(git rev-parse --abbrev-ref HEAD)

worktree_count=$(git worktree list 2>/dev/null | wc -l | tr -d ' ')
if [[ "$worktree_count" -gt 1 ]]; then
  main_worktree=$(git worktree list 2>/dev/null | head -1 | awk '{print $1}')
  main_worktree_name=$(basename "$main_worktree")
  if [[ "$dir_name" == "$main_worktree_name" ]]; then
    base_branch="main"
  else
    base_branch="$dir_name"
  fi
else
  base_branch="main"
fi

if [[ "$current_branch" == "$base_branch" ]]; then
  log_warn "Already on base branch ($base_branch)"
else
  if ! git diff-index --quiet HEAD -- 2>/dev/null; then
    log_error "Uncommitted changes present. Commit or stash first."; exit 1
  fi
fi

log_info "Fetching origin..."
git fetch origin main
occupant=$(git worktree list --porcelain | awk -v b="refs/heads/$base_branch" '
  /^worktree /{p=$2}
  /^branch /{ if ($2==b) print p }
')
if [[ -n "$occupant" && "$occupant" != "$worktree_path" ]]; then
  if [[ -n "$(git -C "$occupant" status --porcelain)" ]]; then
    log_error "$base_branch is checked out in $occupant, which has uncommitted changes. Clean it first."; exit 1
  fi
  home=$(basename "$occupant")
  log_info "Freeing $base_branch from $home (parking $home on its home branch)..."
  git -C "$occupant" checkout "$home" 2>/dev/null || git -C "$occupant" checkout -b "$home"
fi

log_info "Checking out $base_branch branch..."
git checkout "$base_branch"
log_info "Resetting $base_branch to origin/main..."
git reset --hard origin/main

if [[ "$current_branch" != "$base_branch" ]]; then
  log_info "Deleting branch $current_branch..."
  git branch -D "$current_branch" 2>/dev/null || log_warn "Could not delete $current_branch"
fi

if [[ -n "${TMUX:-}" ]]; then
  log_info "Renaming tmux window to <ready>..."
  tmux rename-window -t "$TMUX_PANE" "<ready>"
fi
log_info "Done! Ready for new task on $base_branch."
