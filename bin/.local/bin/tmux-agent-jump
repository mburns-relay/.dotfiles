#!/usr/bin/env bash
# tmux-agent-jump N   (N = 0..5)
#
# Select an agent window in the current tmux session by its WORKTREE, robust to
# workon/finish-task renames and window reordering:
#   1..5 -> the window whose active pane is in ~/relay-commerce/pN (fallback: index N)
#   0    -> the window in ~/relay-commerce/peel2-rails (fallback: last window)
#
# Selecting a window fires the `session-window-changed` hook, which runs
# tmux-chrome-sync to sync the matching Chrome tab. See ~/.local/bin/tmux-chrome-sync.

set -euo pipefail

n="${1:-}"
case "$n" in
  [0-5]) ;;
  *) echo "Usage: tmux-agent-jump <0-5>" >&2; exit 1 ;;
esac

[ -n "${TMUX:-}" ] || exit 0

if [ "$n" = 0 ]; then want="peel2-rails"; else want="p${n}"; fi

win=$(tmux list-windows -F '#{window_index} #{pane_current_path}' | awk -v home="$HOME" -v want="$want" '
  { path = $2; prefix = home "/relay-commerce/"
    if (index(path, prefix) == 1) {
      rest = substr(path, length(prefix) + 1)
      split(rest, parts, "/")
      if (parts[1] == want) { print $1; exit }
    }
  }')

if [ -n "$win" ]; then
  tmux select-window -t "$win"
elif [ "$n" = 0 ]; then
  tmux select-window -t "$(tmux list-windows -F '#{window_index}' | tail -1)"
else
  tmux select-window -t "$n"
fi
