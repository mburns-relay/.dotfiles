#!/usr/bin/env bash
set -euo pipefail
# secret — multi-backend secret accessor (req 14-16).
#
#   secret get  <key>          print a secret
#   secret set  <key> [value]  store a secret (prompts if value omitted)
#   secret rm   <key>          delete a secret
#   secret run  <key=ENVVAR>.. -- cmd...   run cmd with secrets exported
#
# Backends, in priority order:
#   1. 1Password CLI (`op`) when <key> is an op:// reference — biometric.
#   2. macOS login Keychain (generic-password class) — native, machine-local.
#      Stored under service "dotfiles.<key>" for the current user.

SERVICE_PREFIX="dotfiles"

_kc_get() { security find-generic-password -s "${SERVICE_PREFIX}.$1" -a "$USER" -w 2>/dev/null; }
_kc_set() { security add-generic-password -U -s "${SERVICE_PREFIX}.$1" -a "$USER" -w "$2"; }
_kc_rm()  { security delete-generic-password -s "${SERVICE_PREFIX}.$1" -a "$USER" >/dev/null 2>&1 || true; }

get() {
  local key="$1"
  if [[ "$key" == op://* ]]; then
    command -v op >/dev/null || { echo "secret: op not installed for $key" >&2; return 1; }
    op read "$key"
  else
    _kc_get "$key" || { echo "secret: '$key' not found in Keychain" >&2; return 1; }
  fi
}

set_() {
  local key="$1"; local val="${2:-}"
  [[ -z "$val" ]] && { read -rs -p "value for $key: " val; echo; }
  _kc_set "$key" "$val" && echo "secret: stored $key in Keychain"
}

run() {
  local -a exports=()
  while [[ $# -gt 0 && "$1" != "--" ]]; do
    local spec="$1"; shift
    local key="${spec%%=*}"; local var="${spec#*=}"
    exports+=("$var=$(get "$key")")
  done
  [[ "${1:-}" == "--" ]] && shift
  env "${exports[@]}" "$@"
}

case "${1:-}" in
  get) shift; get "$@" ;;
  set) shift; set_ "$@" ;;
  rm)  shift; _kc_rm "$@" ;;
  run) shift; run "$@" ;;
  *) echo "usage: secret {get|set|rm|run} ..." >&2; exit 1 ;;
esac
