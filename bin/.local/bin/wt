#!/usr/bin/env bash
set -euo pipefail
# wt — git worktree helper. Worktrees are siblings of the main checkout, named
# pN, whose home branch is the dir name. Each gets a direnv .envrc exporting PORT.
#
#   wt new pN [base]   create worktree pN (branch pN off base, default origin/main)
#   wt ls              list worktrees
#   wt rm pN           remove worktree pN

RED='\033[0;31m'; GREEN='\033[0;32m'; NC='\033[0m'
die() { echo -e "${RED}wt:${NC} $*" >&2; exit 1; }
info() { echo -e "${GREEN}wt:${NC} $*"; }

main_root() { git worktree list 2>/dev/null | head -1 | awk '{print $1}'; }
container()  { dirname "$(main_root)"; }

cmd_new() {
  local name="${1:-}"; local base="${2:-origin/main}"
  [[ -z "$name" ]] && die "usage: wt new <pN> [base]"
  local path; path="$(container)/$name"
  [[ -e "$path" ]] && die "$path already exists"
  info "fetching origin..."; git fetch origin --quiet || true
  if git show-ref --verify --quiet "refs/heads/$name"; then
    git worktree add "$path" "$name"
  else
    git worktree add -b "$name" "$path" "$base"
  fi
  # Per-worktree isolation: export PORT (3000+N). DB is app-side via Rails.root.
  cat > "$path/.envrc" <<'EOF'
# Auto-generated by `wt`. Web port = 3000 + worktree number.
export PORT=$((3000 + $(get-worktree-num)))
EOF
  command -v direnv >/dev/null && (cd "$path" && direnv allow)
  info "created $path (branch $name, PORT=$((3000 + ${name#p})))"
}

cmd_ls() { git worktree list; }

cmd_rm() {
  local name="${1:-}"; [[ -z "$name" ]] && die "usage: wt rm <pN>"
  git worktree remove "$(container)/$name" && info "removed $name"
}

case "${1:-}" in
  new) shift; cmd_new "$@" ;;
  ls|list) cmd_ls ;;
  rm|remove) shift; cmd_rm "$@" ;;
  *) echo "usage: wt {new|ls|rm} ..." >&2; exit 1 ;;
esac
