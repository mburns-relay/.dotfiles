#!/usr/bin/env bash
# sketchybar — gruvbox-themed top bar for AeroSpace.
# Per-shell status (path, git, exit code, AWS) lives in the Starship prompt and
# tmux status line, where it's accurate; the bar shows workspaces + system.
CONFIG_DIR="$HOME/.config/sketchybar"
PLUGIN_DIR="$CONFIG_DIR/plugins"
source "$CONFIG_DIR/colors.sh"

sketchybar --bar height=34 position=top color=$BAR_COLOR \
                 padding_left=8 padding_right=8 blur_radius=20

default=(
  icon.font="JetBrainsMono Nerd Font:Bold:14.0"
  icon.color=$WHITE
  label.font="JetBrainsMono Nerd Font:Semibold:13.0"
  label.color=$WHITE
  background.color=$ITEM_BG
  background.corner_radius=6
  background.height=24
  padding_left=4 padding_right=4
  label.padding_left=6 label.padding_right=6
  icon.padding_left=8 icon.padding_right=4
)
sketchybar --default "${default[@]}"

# --- AeroSpace workspaces (left) ---
sketchybar --add event aerospace_workspace_change
for wid in 1 2 3 4 5 6 A B S; do
  sketchybar --add item "space.$wid" left \
    --set "space.$wid" label="$wid" \
      click_script="aerospace workspace $wid" \
      script="$PLUGIN_DIR/aerospace.sh" \
    --subscribe "space.$wid" aerospace_workspace_change
done

# --- Front app (left) ---
sketchybar --add item front_app left \
  --set front_app icon.drawing=off script="$PLUGIN_DIR/front_app.sh" \
  --subscribe front_app front_app_switched

# --- Right side: clock, battery ---
sketchybar --add item clock right \
  --set clock update_freq=10 icon=󰥔 script="$PLUGIN_DIR/clock.sh"
sketchybar --add item battery right \
  --set battery update_freq=120 script="$PLUGIN_DIR/battery.sh" \
  --subscribe battery power_source_change

sketchybar --update
