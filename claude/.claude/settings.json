{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "SLASH_COMMAND_TOOL_CHAR_BUDGET": "100000"
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:rubygems.org)",
      "WebFetch(domain:docs.snowflake.com)",
      "WebFetch(domain:help.peelinsights.com)",
      "WebSearch",
      "mcp__shortcut__stories-create",
      "mcp__shortcut__stories-get-by-id",
      "mcp__shortcut__stories-update",
      "mcp__shortcut__stories-search",
      "mcp__shortcut__stories-add-relation",
      "mcp__shortcut__stories-add-task",
      "mcp__shortcut__stories-add-external-link",
      "mcp__shortcut__stories-create-comment",
      "mcp__shortcut__workflows-list",
      "mcp__shortcut__workflows-get-default",
      "mcp__shortcut__teams-list",
      "mcp__shortcut__users-get-current",
      "mcp__shortcut__labels-list",
      "mcp__shortcut__labels-create",
      "Bash(rake test:*)",
      "Bash(bin/rails test:*)",
      "Bash(yarn test:*)",
      "Bash(yarn test)",
      "Bash(npm test:*)",
      "Bash(npm run test:*)",
      "Bash(bundle exec rake test:*)",
      "Bash(bundle exec rails test:*)",
      "Bash(ruby -Itest:*)",
      "Bash(bin/rake test:*)",
      "Bash(bin/ci:*)",
      "Bash(RAILS_ENV=test bin/rails test:*)",
      "Bash(PARALLEL_WORKERS=1 rake test:*)",
      "Bash(yarn test:mutation:*)",
      "Bash(RAILS_ENV=test bundle exec mutant run:*)",
      "Bash(RAILS_ENV=test bundle exec rake:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-tree:*)",
      "Bash(git rebase:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git push origin:*)",
      "Bash(bin/rails db:migrate:*)",
      "Bash(bin/rails db:migrate:status:*)",
      "Bash(bin/rails db:migrate:status:warehouse:*)",
      "Bash(bin/rails db:migrate:warehouse:*)",
      "Bash(bin/rails db:test:prepare:*)",
      "Bash(RAILS_ENV=test bin/rails db:migrate:*)",
      "Bash(bundle install:*)",
      "Bash(yarn build:*)",
      "Bash(npm run build:css:*)",
      "Bash(bin/brakeman:*)",
      "Bash(bundle exec brakeman:*)",
      "Bash(bin/shakapacker:*)",
      "Bash(bin/rails generate:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr create:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(workon:*)",
      "Bash(get-worktree-num)",
      "Bash(finish-task)",
      "Bash(tmux rename-window:*)",
      "Bash(bin/rails routes:*)",
      "Bash(rake -T:*)",
      "Bash(ruby -c:*)"
    ],
    "defaultMode": "plan"
  },
  "model": "claude-opus-4-8[1m]",
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd=$(echo \"$input\" | jq -r '.workspace.current_dir'); pwd_display=\"${cwd/#$HOME/~}\"; if [[ \"$pwd_display\" == \"/\" || \"$pwd_display\" == \"~\" ]]; then final_pwd=\"$pwd_display\"; else final_pwd=\"${pwd_display%/*}/${pwd_display##*/}\"; fi; printf \"\\033[34m%s\\033[0m\" \"$final_pwd\""
  },
  "theme": "dark-daltonized",
  "editorMode": "vim",
  "preferredNotifChannel": "terminal_bell",
  "tui": "fullscreen"
}
