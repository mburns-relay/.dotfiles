# Machine-local git identity — copy to config.local and fill in.
#   cp config.local.example config.local && $EDITOR config.local
# config.local is gitignored, so your real name/email never gets committed.
[user]
	name = Your Name
	email = you@example.com
	# Optional: SSH signing key for `commit.gpgsign`
	# signingkey = ~/.ssh/id_ed25519.pub
